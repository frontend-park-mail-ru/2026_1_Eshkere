{
  "name": "frontend",
  "version": "1.0.0",
  "private": true,
  "main": "server/server.js",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "node server/server.js --dev",
    "start": "npm run build && node server/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,scss,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,scss,css,json}\""
  },
  "prettier": {
    "bracketSpacing": true,
    "singleQuote": true,
    "semi": true
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@eslint/eslintrc": "^3.3.1",
    "babel-loader": "^10.1.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^8.57.1",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "handlebars": "^4.7.8",
    "handlebars-loader": "^1.7.3",
    "html-webpack-plugin": "^5.6.6",
    "prettier": "3.8.1",
    "sass": "^1.98.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-middleware": "^7.4.5"
  }
}
