<header class="navbar">
  <div class="navbar__left">
    <a href="#/" class="navbar__brand">
      <img
        src="./assets/images/logo.png"
        alt="Логотип ЭшкеРеклама"
        class="navbar__logo"
      />

      <div class="navbar__brand-text">
        <span class="navbar__title">ЭшкеРеклама</span>
        <span class="navbar__subtitle">by Эшкере.</span>
      </div>
    </a>

    <nav class="navbar__nav">
      <a href="#/" class="navbar__link">Акции</a>
      <a href="#/" class="navbar__link">Возможности</a>
      <a href="#/" class="navbar__link">Услуги</a>
      <a href="#/" class="navbar__link">Тарифы</a>
    </nav>
  </div>

  <div class="navbar__actions">
    {{#if isAuthenticated}}
      <div class="navbar__actions-user">
        <div class="navbar__balance">{{user.balance}} ₽</div>
        <button class="navbar__actions-user-icon" type="button">
          <svg width="19" height="18" viewBox="0 0 19 18" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M2 18C1.45 18 0.979167 17.8042 0.5875 17.4125C0.195833 17.0208 0 16.55 0 16V2C0 1.45 0.195833 0.979167 0.5875 0.5875C0.979167 0.195833 1.45 0 2 0H16C16.55 0 17.0208 0.195833 17.4125 0.5875C17.8042 0.979167 18 1.45 18 2V4.5H16V2H2V16H16V13.5H18V16C18 16.55 17.8042 17.0208 17.4125 17.4125C17.0208 17.8042 16.55 18 16 18H2ZM10 14C9.45 14 8.97917 13.8042 8.5875 13.4125C8.19583 13.0208 8 12.55 8 12V6C8 5.45 8.19583 4.97917 8.5875 4.5875C8.97917 4.19583 9.45 4 10 4H17C17.55 4 18.0208 4.19583 18.4125 4.5875C18.8042 4.97917 19 5.45 19 6V12C19 12.55 18.8042 13.0208 18.4125 13.4125C18.0208 13.8042 17.55 14 17 14H10ZM17 12V6H10V12H17ZM14.0625 10.0625C14.3542 9.77083 14.5 9.41667 14.5 9C14.5 8.58333 14.3542 8.22917 14.0625 7.9375C13.7708 7.64583 13.4167 7.5 13 7.5C12.5833 7.5 12.2292 7.64583 11.9375 7.9375C11.6458 8.22917 11.5 8.58333 11.5 9C11.5 9.41667 11.6458 9.77083 11.9375 10.0625C12.2292 10.3542 12.5833 10.5 13 10.5C13.4167 10.5 13.7708 10.3542 14.0625 10.0625Z" fill="#5552FF"/>
          </svg>
        </button>
        <button class="navbar__actions-user-icon" type="button">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 19V17H6V10C6 8.61667 6.41667 7.3875 7.25 6.3125C8.08333 5.2375 9.16667 4.53333 10.5 4.2V3.5C10.5 3.08333 10.6458 2.72917 10.9375 2.4375C11.2292 2.14583 11.5833 2 12 2C12.4167 2 12.7708 2.14583 13.0625 2.4375C13.3542 2.72917 13.5 3.08333 13.5 3.5V4.2C14.8333 4.53333 15.9167 5.2375 16.75 6.3125C17.5833 7.3875 18 8.61667 18 10V17H20V19H4ZM12 22C11.45 22 10.9792 21.8042 10.5875 21.4125C10.1958 21.0208 10 20.55 10 20H14C14 20.55 13.8042 21.0208 13.4125 21.4125C13.0208 21.8042 12.55 22 12 22ZM8 17H16V10C16 8.9 15.6083 7.95833 14.825 7.175C14.0417 6.39167 13.1 6 12 6C10.9 6 9.95833 6.39167 9.175 7.175C8.39167 7.95833 8 8.9 8 10V17Z" fill="#5552FF"/>
          </svg>
        </button>
        <img class="navbar__avatar" src="{{user.avatar}}" alt="{{user.name}}" />
        <button
          class="navbar__profile-toggle"
          type="button"
          id="navbar-profile-toggle"
          aria-expanded="false"
          aria-controls="navbar-profile-menu"
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4.5 6.75L9 11.25L13.5 6.75" stroke="#5A54FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div class="navbar__profile-menu" id="navbar-profile-menu" hidden>
          <button class="navbar__profile-menu-head" type="button">
            <img class="navbar__profile-menu-avatar" src="{{user.avatar}}" alt="{{user.name}}" />
            <span class="navbar__profile-menu-name">{{user.name}}</span>
            <span class="navbar__profile-menu-arrow">›</span>
          </button>
          <button class="navbar__profile-menu-logout" type="button" id="navbar-logout-button">
            Выйти
          </button>
        </div>

        <div class="navbar__logout-modal" id="navbar-logout-modal" hidden>
          <div class="navbar__logout-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="navbar-logout-modal-title">
            <h3 class="navbar__logout-modal-title" id="navbar-logout-modal-title">
              Вы уверены, что вы хотите выйти?
            </h3>
            <img
              class="navbar__logout-modal-image"
              src="./assets/images/Bored.png"
              alt=""
            />
            <div class="navbar__logout-modal-actions">
              <button type="button" class="navbar__logout-modal-button navbar__logout-modal-button--yes" id="navbar-logout-confirm">
                Да
              </button>
              <button type="button" class="navbar__logout-modal-button navbar__logout-modal-button--no" id="navbar-logout-cancel">
                Нет
              </button>
            </div>
          </div>
        </div>

        {{!-- <div class="navbar__avata">
          <img src="{{user.avatar}}" alt="{{user.name}}" />
        </div> --}}
      </div>

    {{else}}
      <a
        href="#/login"
        class="navbar__button navbar__button--ghost {{#if isLogin}}is-active{{/if}}"
      >
        Вход
      </a>

      <a
        href="#/register"
        class="navbar__button navbar__button--primary {{#if isRegister}}is-active{{/if}}"
      >
        Регистрация
      </a>
    {{/if}}
  </div>
</header>
