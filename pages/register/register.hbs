<section class="auth-page">
  <div class="auth-card">
    <h1 class="auth-card__title">Регистрация</h1>

    <form class="auth-form" id="register-form">
      {{{emailField}}}
      {{{phoneField}}}
      {{{passwordField}}}
      {{{repeatPasswordField}}}

      <div class="auth-form-not-input">
        {{{submitButton}}}
        {{{loginLinkButton}}}

        <div class="auth-divider">
          <span>или</span>
        </div>

        <button type="button" class="social-button social-button--vk" disabled aria-disabled="true" title="Скоро будет доступно">
          <span class="social-button__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img" focusable="false">
              <rect x="1" y="1" width="22" height="22" rx="6" fill="#0077FF"></rect>
              <text x="12" y="15" text-anchor="middle" font-size="8" font-weight="700" font-family="Arial, sans-serif" fill="#FFFFFF">VK</text>
            </svg>
          </span>
          <span class="social-button__label">VK ID</span>
        </button>
        <button type="button" class="social-button social-button--google" disabled aria-disabled="true" title="Скоро будет доступно">
          <span class="social-button__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img" focusable="false">
              <circle cx="12" cy="12" r="11" fill="#FFFFFF" stroke="#DADCE0"></circle>
              <path d="M20 12.2c0-.7-.1-1.3-.2-1.9H12v3.6h4.5c-.2 1.1-.8 2-1.7 2.6v2.2h2.7c1.6-1.4 2.5-3.6 2.5-6.5z" fill="#4285F4"></path>
              <path d="M12 20.2c2.2 0 4-.7 5.3-1.9l-2.7-2.2c-.7.5-1.6.9-2.7.9-2 0-3.7-1.4-4.3-3.2H4.8v2.3c1.3 2.5 4 4.1 7.2 4.1z" fill="#34A853"></path>
              <path d="M7.7 13.8c-.2-.5-.3-1.1-.3-1.8s.1-1.2.3-1.8V7.9H4.8C4.3 8.9 4 10 4 12s.3 3.1.8 4.1l2.9-2.3z" fill="#FBBC05"></path>
              <path d="M12 7.1c1.2 0 2.2.4 3 1.1l2.2-2.2C16 4.7 14.2 4 12 4 8.8 4 6.1 5.7 4.8 8.2l2.9 2.3c.6-1.9 2.3-3.4 4.3-3.4z" fill="#EA4335"></path>
            </svg>
          </span>
          <span class="social-button__label">Google</span>
        </button>
        <button type="button" class="social-button social-button--yandex" disabled aria-disabled="true" title="Скоро будет доступно">
          <span class="social-button__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img" focusable="false">
              <circle cx="12" cy="12" r="11" fill="#FC3F1D"></circle>
              <text x="12" y="16" text-anchor="middle" font-size="12" font-weight="700" font-family="Arial, sans-serif" fill="#FFFFFF">Я</text>
            </svg>
          </span>
          <span class="social-button__label">Яндекс ID</span>
        </button>
      </div>
    </form>
  </div>
</section>
