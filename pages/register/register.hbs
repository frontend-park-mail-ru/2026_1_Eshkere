<section class="auth-page">
  <div class="auth-card">
    <h1 class="auth-card__title">Регистрация</h1>

    <form class="auth-form" id="register-form">
      {{{emailField}}}
      {{{phoneField}}}
      {{{passwordField}}}
      {{{repeatPasswordField}}}

      <div class="auth-form-not-input">
        {{{submitButton}}}
        {{{loginLinkButton}}}

        <div class="auth-divider">
          <span>или</span>
        </div>

        <button type="button" class="social-button">ВКонтакте</button>
        <button type="button" class="social-button">Google</button>
        <button type="button" class="social-button">Яндекс ID</button>
      </div>
    </form>
  </div>
</section>