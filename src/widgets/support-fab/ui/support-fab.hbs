<div class="support-fab" id="{{rootId}}">
  <button
    class="support-fab__button"
    type="button"
    data-support-fab-toggle
    aria-label="Открыть техподдержку"
  >
    <span class="support-fab__button-icon" aria-hidden="true">?</span>
    <span class="support-fab__button-text">Поддержка</span>
  </button>

  <section
    class="support-fab__panel"
    data-support-fab-panel
    hidden
    aria-label="Техподдержка"
  >
    <iframe
      class="support-fab__iframe"
      src="{{iframeSrc}}"
      title="Виджет техподдержки"
      loading="lazy"
      referrerpolicy="strict-origin-when-cross-origin"
    ></iframe>
  </section>
</div>
