<section class="auth-page forgot-password-page">
  <div class="auth-card auth-card--compact">
    <div class="forgot-password-panel" data-forgot-password-form>
      <h1 class="auth-card__title auth-card__title--small">Восстановление пароля</h1>

      <form class="auth-form" id="forgot-password-form">
        {{{restoreField}}}

        <div class="auth-form-not-input auth-form-not-input--compact">
          {{{submitButton}}}
          {{{helpButton}}}
          {{{backButton}}}
        </div>
      </form>
    </div>
  </div>

  <div class="modal" id="forgot-password-help-modal" aria-hidden="true">
    <div class="modal__backdrop" data-modal-close></div>
    <div class="modal__content" role="dialog" aria-modal="true" aria-labelledby="forgot-password-help-title">
      <div class="modal__inner forgot-password-modal">
        <button
          class="forgot-password-modal__close"
          type="button"
          aria-label="Закрыть уведомление"
          data-modal-close
        >
          &times;
        </button>

        <h2 class="forgot-password-modal__title" id="forgot-password-help-title">Помощь</h2>
        <p class="forgot-password-modal__text">
          Напишите нашему Тим лиду <strong>@chocaboy</strong> в телеграмме, он точно со всем разберется
        </p>
      </div>
    </div>
  </div>
</section>
