<div class="stats-page" data-campaign-stats>
  <header class="stats-header">
    <button class="stats-header__back" type="button" data-cs-back>← Кампания</button>
    <div class="stats-header__info">
      <div class="stats-header__eyebrow">Статистика кампании</div>
      <h1 class="stats-header__title" data-cs-title>Загрузка…</h1>
      <div class="stats-header__meta">
        <span class="stats-badge stats-badge--warning" data-cs-status>—</span>
        <span class="stats-header__tag" data-cs-goal>—</span>
        <span class="stats-header__tag" data-cs-budget>—</span>
      </div>
    </div>
    <div class="stats-periods" data-cs-periods>
      <button class="stats-period stats-period--active" type="button" data-period="7">7 дней</button>
      <button class="stats-period" type="button" data-period="30">30 дней</button>
      <button class="stats-period" type="button" data-period="90">90 дней</button>
    </div>
  </header>

  <div class="stats-kpis">
    <div class="stats-kpi">
      <span class="stats-kpi__label">Показы</span>
      <span class="stats-kpi__value" data-cs-kpi="impressions">—</span>
      <span class="stats-kpi__delta stats-kpi__delta--up" data-cs-delta="impressions"></span>
    </div>
    <div class="stats-kpi">
      <span class="stats-kpi__label">Клики</span>
      <span class="stats-kpi__value" data-cs-kpi="clicks">—</span>
      <span class="stats-kpi__delta stats-kpi__delta--up" data-cs-delta="clicks"></span>
    </div>
    <div class="stats-kpi">
      <span class="stats-kpi__label">CTR</span>
      <span class="stats-kpi__value" data-cs-kpi="ctr">—</span>
      <span class="stats-kpi__delta stats-kpi__delta--up" data-cs-delta="ctr"></span>
    </div>
    <div class="stats-kpi">
      <span class="stats-kpi__label">Потрачено</span>
      <span class="stats-kpi__value" data-cs-kpi="spend">—</span>
      <span class="stats-kpi__delta stats-kpi__delta--down" data-cs-delta="spend"></span>
    </div>
    <div class="stats-kpi">
      <span class="stats-kpi__label">CPC</span>
      <span class="stats-kpi__value" data-cs-kpi="cpc">—</span>
      <span class="stats-kpi__delta stats-kpi__delta--up" data-cs-delta="cpc"></span>
    </div>
  </div>

  <div class="stats-card">
    <div class="stats-card__head">
      <h2 class="stats-card__title">Динамика</h2>
      <span class="stats-card__note">Показы за период</span>
    </div>
    <div class="stats-chart" data-cs-chart></div>
    <div class="stats-chart__labels" data-cs-chart-labels></div>
  </div>

  <div class="stats-card">
    <div class="stats-card__head">
      <h2 class="stats-card__title">Использование бюджета</h2>
      <span class="stats-card__note" data-cs-budget-note>—</span>
    </div>
    <div class="stats-breakdown">
      <div class="stats-breakdown__row">
        <span class="stats-breakdown__label">Потрачено</span>
        <div class="stats-breakdown__bar-wrap">
          <div class="stats-breakdown__bar" data-cs-budget-bar style="width:0%"></div>
        </div>
        <span class="stats-breakdown__val" data-cs-budget-spent>—</span>
      </div>
    </div>
  </div>

  <div class="stats-card">
    <div class="stats-card__head">
      <h2 class="stats-card__title">Группы объявлений</h2>
      <span class="stats-card__note">Вклад в результат кампании</span>
    </div>
    <table class="stats-table">
      <thead>
        <tr>
          <th>Название</th>
          <th>Показы</th>
          <th>Клики</th>
          <th>CTR</th>
          <th>Потрачено</th>
          <th>Статус</th>
          <th></th>
        </tr>
      </thead>
      <tbody data-cs-groups-table>
        <tr><td colspan="7" style="text-align:center;color:var(--text-note);padding:24px">Загрузка…</td></tr>
      </tbody>
    </table>
  </div>
</div>
