<div class="gs-page" data-group-stats>

  <div class="as-toolbar">
    <button class="as-back-btn" type="button" data-gs-back>← Назад к кампании</button>
    <nav class="as-breadcrumb" aria-label="Навигация">
      <button class="as-breadcrumb__item" type="button" data-gs-bc-campaigns>Кампании</button>
      <span class="as-breadcrumb__sep">›</span>
      <button class="as-breadcrumb__item" type="button" data-gs-bc-campaign>—</button>
      <span class="as-breadcrumb__sep">›</span>
      <span class="as-breadcrumb__item as-breadcrumb__item--active">Статистика группы</span>
    </nav>
  </div>

  <div class="stats-card gs-hero">
    <div class="gs-hero__main">
      <div class="gs-hero__top">
        <h1 class="gs-hero__title" data-gs-title>Загрузка…</h1>
        <span class="stats-badge stats-badge--success" data-gs-status>Активна</span>
      </div>
      <div class="gs-hero__meta" data-gs-meta></div>
    </div>
    <div class="cs-hero__controls">
      <div class="stats-periods" data-gs-periods>
        <button class="stats-period" type="button" data-period="7">7 дней</button>
        <button class="stats-period stats-period--active" type="button" data-period="30">30 дней</button>
        <button class="stats-period" type="button" data-period="90">90 дней</button>
        <button class="stats-period" type="button" data-period="0">Весь срок</button>
      </div>
      <button class="as-edit-btn" type="button" data-gs-settings>⚙ Настройки</button>
    </div>
  </div>

  <div class="gs-metrics">
    <div class="as-metric">
      <span class="as-metric__label">ПОКАЗЫ</span>
      <strong class="as-metric__value" data-gs-kpi="impressions">—</strong>
      <span class="as-metric__delta" data-gs-delta="impressions">—</span>
    </div>
    <div class="as-metric">
      <span class="as-metric__label">КЛИКИ</span>
      <strong class="as-metric__value" data-gs-kpi="clicks">—</strong>
      <span class="as-metric__delta" data-gs-delta="clicks">—</span>
    </div>
    <div class="as-metric as-metric--accent gs-metric--best">
      <span class="as-metric__label">CTR</span>
      <strong class="as-metric__value" data-gs-kpi="ctr">—</strong>
      <span class="gs-best-label">Лучший</span>
    </div>
    <div class="as-metric">
      <span class="as-metric__label">РАСХОД</span>
      <strong class="as-metric__value" data-gs-kpi="spend">—</strong>
      <span class="as-metric__delta" data-gs-delta="spend">—</span>
    </div>
    <div class="as-metric">
      <span class="as-metric__label">CPC</span>
      <strong class="as-metric__value" data-gs-kpi="cpc">—</strong>
      <span class="as-metric__delta" data-gs-delta="cpc">—</span>
    </div>
  </div>

  <div class="cs-main-grid gs-main-grid">
    <div class="stats-card cs-chart-card">
      <div class="cs-chart-head">
        <div>
          <h2 class="stats-card__title" data-gs-chart-title>Динамика CTR</h2>
          <span class="cs-chart-subtitle" data-gs-chart-subtitle>—</span>
        </div>
      </div>
      <div class="as-metric-tabs" data-gs-metric-tabs>
        <button class="as-metric-tab" type="button" data-metric="impressions">Показы</button>
        <button class="as-metric-tab" type="button" data-metric="clicks">Клики</button>
        <button class="as-metric-tab as-metric-tab--active" type="button" data-metric="ctr">CTR</button>
        <button class="as-metric-tab" type="button" data-metric="spend">Расход</button>
      </div>
      <div class="cs-line-wrap">
        <svg class="cs-line-chart gs-line-chart" viewBox="0 0 700 200" aria-hidden="true" data-gs-line-chart>
          <defs>
            <linearGradient id="gs-grad" x1="0%" y1="0%" x2="0%" y2="100%">
              <stop offset="0%" stop-color="rgba(34,197,94,0.22)"></stop>
              <stop offset="100%" stop-color="rgba(34,197,94,0)"></stop>
            </linearGradient>
          </defs>
        </svg>
        <div class="as-line-labels" data-gs-line-labels></div>
      </div>
    </div>

    <div class="stats-card gs-audience">
      <h2 class="stats-card__title">Аудитория</h2>
      <div class="gs-audience-section">
        <div class="gs-audience-section__label">ВОЗРАСТ</div>
        <div class="gs-audience-rows" data-gs-age></div>
      </div>
      <div class="gs-audience-section">
        <div class="gs-audience-section__label">ПОЛ</div>
        <div class="gs-audience-rows" data-gs-gender></div>
      </div>
      <div class="gs-audience-section">
        <div class="gs-audience-section__label">РЕГИОНЫ</div>
        <div class="gs-audience-rows" data-gs-regions></div>
      </div>
    </div>
  </div>

  <div class="gs-stat-cards">
    <div class="stats-card gs-stat-card">
      <span class="gs-stat-card__label">БЮДЖЕТ ИСПОЛЬЗОВАН</span>
      <div class="gs-stat-card__body">
        <svg class="gs-donut" viewBox="0 0 80 80" aria-hidden="true" data-gs-donut="budget">
          <circle class="gs-donut__bg" cx="40" cy="40" r="28"></circle>
          <circle class="gs-donut__arc gs-donut__arc--purple" cx="40" cy="40" r="28" data-gs-donut-arc="budget"></circle>
        </svg>
        <div>
          <strong class="gs-stat-card__value" data-gs-stat="budget-pct">—</strong>
          <span class="gs-stat-card__sub" data-gs-stat="budget-sub">—</span>
        </div>
      </div>
    </div>

    <div class="stats-card gs-stat-card">
      <span class="gs-stat-card__label">ЧАСТОТА ПОКАЗОВ</span>
      <div class="gs-stat-card__body">
        <svg class="gs-donut" viewBox="0 0 80 80" aria-hidden="true">
          <circle class="gs-donut__bg" cx="40" cy="40" r="28"></circle>
          <circle class="gs-donut__arc gs-donut__arc--green" cx="40" cy="40" r="28" data-gs-donut-arc="freq"></circle>
        </svg>
        <div>
          <strong class="gs-stat-card__value" data-gs-stat="freq">—</strong>
          <span class="gs-stat-card__sub">Среднее число показов на пользователя</span>
        </div>
      </div>
    </div>

    <div class="stats-card gs-stat-card">
      <span class="gs-stat-card__label">ТЕМП РАСХОДА</span>
      <div class="gs-stat-card__body">
        <svg class="gs-donut" viewBox="0 0 80 80" aria-hidden="true">
          <circle class="gs-donut__bg" cx="40" cy="40" r="28"></circle>
          <circle class="gs-donut__arc gs-donut__arc--orange" cx="40" cy="40" r="28" data-gs-donut-arc="pace"></circle>
        </svg>
        <div>
          <strong class="gs-stat-card__value" data-gs-stat="pace">—</strong>
          <span class="gs-stat-card__sub" data-gs-stat="pace-sub">—</span>
        </div>
      </div>
    </div>
  </div>

  <div class="stats-card gs-heatmap-card">
    <div class="stats-card__head">
      <div>
        <h2 class="stats-card__title">Тепловая карта активности</h2>
        <span class="cs-chart-subtitle">Клики по дням недели и часам суток</span>
      </div>
    </div>
    <div class="gs-heatmap-wrap">
      <div class="gs-heatmap" data-gs-heatmap></div>
      <div class="gs-heatmap-legend">
        <span>Меньше</span>
        <span class="gs-heatmap-legend__swatch gs-heatmap-legend__swatch--1"></span>
        <span class="gs-heatmap-legend__swatch gs-heatmap-legend__swatch--2"></span>
        <span class="gs-heatmap-legend__swatch gs-heatmap-legend__swatch--3"></span>
        <span class="gs-heatmap-legend__swatch gs-heatmap-legend__swatch--4"></span>
        <span>Больше</span>
      </div>
    </div>
  </div>

  <div class="stats-card">
    <div class="stats-card__head">
      <div>
        <h2 class="stats-card__title">Объявления в группе</h2>
        <span class="cs-table-meta" data-gs-ads-count>—</span>
      </div>
      <button class="as-link-btn" type="button">↓ Экспорт</button>
    </div>
    <table class="stats-table">
      <thead>
        <tr>
          <th>ОБЪЯВЛЕНИЕ</th>
          <th>СТАТУС</th>
          <th>ПОКАЗЫ</th>
          <th>КЛИКИ</th>
          <th>CTR</th>
          <th>РАСХОД</th>
          <th>CPC</th>
        </tr>
      </thead>
      <tbody data-gs-ads-table>
        <tr><td colspan="7" class="as-table-loading">Загрузка…</td></tr>
      </tbody>
    </table>
  </div>

</div>
