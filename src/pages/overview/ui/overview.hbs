<section class="overview-page" data-overview-page>
  <div class="overview-page__hero">
    <div class="overview-page__hero-copy">
      <span class="overview-page__eyebrow">Обзор кабинета</span>
      <h1 class="overview-page__title">Что происходит сейчас</h1>
      <p class="overview-page__subtitle">
        Кампании, объявления, модерация и деньги в одном рабочем срезе.
      </p>
    </div>

    <div class="overview-page__hero-actions">
      <a class="overview-page__secondary-action" href="/ads" data-overview-link>Кампании</a>
      <a class="overview-page__primary-action" href="/ads/create" data-overview-link>Создать кампанию</a>
    </div>
  </div>

  {{#if loadError}}
    <div class="overview-page__notice">
      {{loadError}}
    </div>
  {{/if}}

  <div class="overview-page__stats">
    {{#each stats}}
      <article class="overview-stat overview-stat--{{tone}}">
        <span class="overview-stat__label">{{label}}</span>
        <strong class="overview-stat__value">{{value}}</strong>
        <span class="overview-stat__note">{{note}}</span>
      </article>
    {{/each}}
  </div>

  <div class="overview-page__grid">
    <section class="overview-card overview-card--wide">
      <div class="overview-card__head">
        <div>
          <h2 class="overview-card__title">Структура кабинета</h2>
          <p class="overview-card__subtitle">Что уже создано и где есть незаполненные места</p>
        </div>
      </div>

      <div class="overview-chart" aria-hidden="true">
        {{#each chart}}
          <div class="overview-chart__item">
            <span class="overview-chart__bar" style="height: {{height}}%"></span>
            <strong class="overview-chart__value">{{value}}</strong>
            <span class="overview-chart__label">{{label}}</span>
          </div>
        {{/each}}
      </div>
    </section>

    <section class="overview-card">
      <div class="overview-card__head">
        <div>
          <h2 class="overview-card__title">Статусы</h2>
          <p class="overview-card__subtitle">Распределение кампаний</p>
        </div>
      </div>

      {{#if hasStatuses}}
        <div class="overview-status-list">
          {{#each statusItems}}
            <div class="overview-status overview-status--{{tone}}">
              <div class="overview-status__row">
                <span>{{label}}</span>
                <strong>{{value}}</strong>
              </div>
              <span class="overview-status__track">
                <span class="overview-status__fill" style="width: {{width}}%"></span>
              </span>
            </div>
          {{/each}}
        </div>
      {{else}}
        <div class="overview-empty">
          <strong>Кампаний пока нет</strong>
          <span>После создания здесь появится распределение по статусам.</span>
        </div>
      {{/if}}
    </section>

    <section class="overview-card">
      <div class="overview-card__head">
        <div>
          <h2 class="overview-card__title">Что требует внимания</h2>
          <p class="overview-card__subtitle">Короткий список ближайших действий</p>
        </div>
      </div>

      <div class="overview-actions">
        {{#each recommendations}}
          <a class="overview-action overview-action--{{tone}}" href="{{href}}" data-overview-link>
            <span class="overview-action__marker"></span>
            <span class="overview-action__body">
              <strong>{{title}}</strong>
              <span>{{text}}</span>
            </span>
            <span class="overview-action__button">{{actionLabel}}</span>
          </a>
        {{/each}}
      </div>
    </section>

    <section class="overview-card overview-card--wide">
      <div class="overview-card__head overview-card__head--with-action">
        <div>
          <h2 class="overview-card__title">Последние кампании</h2>
          <p class="overview-card__subtitle">Быстрый переход к текущей структуре</p>
        </div>
        <a class="overview-card__link" href="/ads" data-overview-link>Все кампании</a>
      </div>

      {{#if hasRecentCampaigns}}
        <div class="overview-campaigns">
          {{#each recentCampaigns}}
            <a class="overview-campaign overview-campaign--{{tone}}" href="{{href}}" data-overview-link>
              <span class="overview-campaign__main">
                <strong>{{title}}</strong>
                <span>{{meta}}</span>
              </span>
              <span class="overview-campaign__status">{{status}}</span>
            </a>
          {{/each}}
        </div>
      {{else}}
        <div class="overview-empty overview-empty--inline">
          <strong>Нет кампаний для показа</strong>
          <span>Создайте первую кампанию, чтобы обзор стал информативным.</span>
        </div>
      {{/if}}
    </section>

    <section class="overview-card overview-card--balance">
      <div class="overview-card__head">
        <div>
          <h2 class="overview-card__title">Финансы</h2>
          <p class="overview-card__subtitle">Доступный баланс кабинета</p>
        </div>
      </div>

      <div class="overview-balance">
        <strong>{{balance}}</strong>
        <a href="/balance" data-overview-link>Открыть баланс</a>
      </div>
    </section>
  </div>
</section>
