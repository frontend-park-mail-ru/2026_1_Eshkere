<section class="campaign-builder add-sites-block" data-add-sites-block>
  <div class="campaign-builder__toolbar">
    <div class="campaign-builder__toolbar-group">
      <a class="campaign-builder__button campaign-builder__button--secondary" href="{{backHref}}">
        ← Площадки
      </a>
    </div>
  </div>

  <section class="campaign-builder__hero">
    <div class="campaign-builder__hero-copy">
      <h1 class="campaign-builder__title">Рекламный блок</h1>
      <p class="campaign-builder__subtitle" data-asb-subtitle>
        Выберите тип блока и укажите название.
      </p>
    </div>
    <div class="campaign-builder__steps add-sites-block__steps">
      <div
        class="campaign-builder__step campaign-builder__step--active add-sites-block__hero-step"
        data-asb-hero-step="1"
      >
        <span class="campaign-builder__step-index">1</span>
        <strong class="campaign-builder__step-title">Настройка типа блока</strong>
      </div>
      <div class="campaign-builder__step add-sites-block__hero-step" data-asb-hero-step="2">
        <span class="campaign-builder__step-index">2</span>
        <strong class="campaign-builder__step-title">Код для вставки</strong>
      </div>
    </div>
  </section>

  <div class="campaign-builder__layout">
    <div class="campaign-builder__main">
      <section class="campaign-builder__panel" data-asb-panel="1">
        <div class="campaign-builder__card">
          <div class="campaign-builder__card-head">
            <h2 class="campaign-builder__card-title">Настройка типа блока</h2>
            <p class="campaign-builder__card-subtitle">
              Выберите формат блока и укажите название — так вы отличите его в списке площадки.
            </p>
          </div>

          <form
            class="campaign-builder__form block-type-picker"
            id="add-sites-block-form"
            data-block-type-picker
            novalidate
          >
            <h3 class="block-type-picker__heading" id="block-type-picker-label">
              Выберите тип рекламного блока
            </h3>

            <div
              class="block-type-picker__grid"
              role="radiogroup"
              aria-labelledby="block-type-picker-label"
            >
              <label class="block-type-card">
                <input class="block-type-card__input" type="radio" name="block_type" value="banner" />
                <span class="block-type-card__radio" aria-hidden="true"></span>
                <span class="block-type-card__icon" aria-hidden="true">
                  <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="5" y="8" width="18" height="13" rx="2" stroke="currentColor" stroke-width="1.6"/>
                    <path d="M23 14h6a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H15" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                  </svg>
                </span>
                <span class="block-type-card__body">
                  <strong class="block-type-card__title">Баннер</strong>
                  <span class="block-type-card__desc">
                    Универсальный рекламный блок для размещения в выделенном контейнере на странице
                  </span>
                </span>
              </label>

              <label class="block-type-card">
                <input class="block-type-card__input" type="radio" name="block_type" value="fullscreen" />
                <span class="block-type-card__radio" aria-hidden="true"></span>
                <span class="block-type-card__icon" aria-hidden="true">
                  <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="4" y="5" width="28" height="22" rx="2" stroke="currentColor" stroke-width="1.6"/>
                    <path d="M4 10h28" stroke="currentColor" stroke-width="1.6"/>
                    <circle cx="18" cy="25" r="1.5" fill="currentColor"/>
                  </svg>
                </span>
                <span class="block-type-card__body">
                  <strong class="block-type-card__title">Полноэкранный</strong>
                  <span class="block-type-card__desc">
                    Рекламный блок отображается на весь экран и перекрывает содержимое страницы
                  </span>
                </span>
              </label>

              <label class="block-type-card">
                <input class="block-type-card__input" type="radio" name="block_type" value="floor_ad" />
                <span class="block-type-card__radio" aria-hidden="true"></span>
                <span class="block-type-card__icon" aria-hidden="true">
                  <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="5" y="6" width="26" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/>
                    <rect x="5" y="24" width="26" height="6" rx="1" stroke="currentColor" stroke-width="1.6" fill="currentColor" fill-opacity="0.12"/>
                  </svg>
                </span>
                <span class="block-type-card__body">
                  <strong class="block-type-card__title">Floor Ad</strong>
                  <span class="block-type-card__desc">
                    Рекламный блок фиксируется в нижней части экрана поверх контента и занимает всю ширину
                  </span>
                </span>
              </label>

              <label class="block-type-card">
                <input class="block-type-card__input" type="radio" name="block_type" value="top_ad" />
                <span class="block-type-card__radio" aria-hidden="true"></span>
                <span class="block-type-card__icon" aria-hidden="true">
                  <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="5" y="6" width="26" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/>
                    <rect x="5" y="6" width="26" height="5" rx="1" stroke="currentColor" stroke-width="1.6" fill="currentColor" fill-opacity="0.12"/>
                  </svg>
                </span>
                <span class="block-type-card__body">
                  <strong class="block-type-card__title">Top Ad</strong>
                  <span class="block-type-card__desc">
                    Мобильный рекламный блок фиксируется в верхней части экрана поверх контента и занимает всю ширину
                  </span>
                </span>
              </label>

              <label class="block-type-card">
                <input class="block-type-card__input" type="radio" name="block_type" value="feed" checked />
                <span class="block-type-card__radio" aria-hidden="true"></span>
                <span class="block-type-card__icon" aria-hidden="true">
                  <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="6" y="7" width="24" height="5" rx="1" stroke="currentColor" stroke-width="1.4"/>
                    <rect x="6" y="15" width="24" height="5" rx="1" stroke="currentColor" stroke-width="1.4"/>
                    <rect x="6" y="23" width="24" height="5" rx="1" stroke="currentColor" stroke-width="1.4"/>
                  </svg>
                </span>
                <span class="block-type-card__body">
                  <strong class="block-type-card__title">Лента</strong>
                  <span class="block-type-card__desc">
                    Рекламный блок в формате ленты объявлений, размещается под основным контентом страницы
                  </span>
                </span>
              </label>

              <label class="block-type-card">
                <input class="block-type-card__input" type="radio" name="block_type" value="in_image" />
                <span class="block-type-card__radio" aria-hidden="true"></span>
                <span class="block-type-card__icon" aria-hidden="true">
                  <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="5" y="9" width="26" height="16" rx="2" stroke="currentColor" stroke-width="1.6"/>
                    <circle cx="18" cy="17" r="4" stroke="currentColor" stroke-width="1.4"/>
                    <rect x="12" y="13" width="12" height="10" rx="1" stroke="currentColor" stroke-width="1.2" fill="currentColor" fill-opacity="0.15"/>
                  </svg>
                </span>
                <span class="block-type-card__body">
                  <strong class="block-type-card__title">In-Image</strong>
                  <span class="block-type-card__desc">
                    Рекламный блок фиксируется поверх изображений на сайте
                  </span>
                </span>
              </label>
            </div>

            <div class="block-type-picker__name-field">
              {{{blockNameField}}}
            </div>
          </form>
        </div>
      </section>

      <section class="campaign-builder__panel" data-asb-panel="2" hidden>
        <div class="campaign-builder__card">
            <div id="add-sites-block-embed" class="add-sites-block__embed add-sites-block__embed--panel" tabindex="-1">
              <div class="add-sites-block__embed-success">
                <span class="add-sites-block__embed-success-icon" aria-hidden="true">🎉</span>
                <p class="add-sites-block__embed-success-title">Вы создали рекламный блок!</p>
                <p class="add-sites-block__embed-success-lead">
                  Скопируйте фрагменты ниже и вставьте на сайт: SDK в <code class="add-sites-block__embed-inline-code">&lt;head&gt;</code>, блок — в нужное место в <code class="add-sites-block__embed-inline-code">&lt;body&gt;</code>.
                </p>
              </div>

              <section class="add-sites-block__embed-step" aria-labelledby="asb-embed-sdk-title">
                <h3 class="add-sites-block__embed-step-title" id="asb-embed-sdk-title">
                  Подключите SDK (поле <span class="add-sites-block__embed-mono">script_url</span>)
                </h3>
                <p class="add-sites-block__embed-step-lead">
                  Скопируйте код в буфер обмена и вставьте в секцию <code class="add-sites-block__embed-inline-code">&lt;head&gt;</code>
                  страницы. Загрузчик подключается один раз на страницу.
                </p>
                <pre class="add-sites-block__embed-pre" role="region" aria-label="Пример кода SDK"><code id="asb-code-sdk" class="add-sites-block__embed-code"></code></pre>
                <button
                  type="button"
                  class="add-sites-block__embed-copy"
                  data-asb-copy="#asb-code-sdk"
                >
                  Копировать в буфер обмена
                </button>
              </section>

              <section class="add-sites-block__embed-step" aria-labelledby="asb-embed-snippet-title">
                <h3 class="add-sites-block__embed-step-title" id="asb-embed-snippet-title">
                  Код рекламного блока (поле <span class="add-sites-block__embed-mono">html_snippet</span>)
                </h3>
                <p class="add-sites-block__embed-step-lead">
                  Скопируйте фрагмент и вставьте в <code class="add-sites-block__embed-inline-code">&lt;body&gt;</code>
                  там, где должен отображаться блок. В спецификации: разметка вида
                  <code class="add-sites-block__embed-inline-code">div data-eshkere-ad</code>
                  и сценарий инициализации.
                </p>
                <pre class="add-sites-block__embed-pre" role="region" aria-label="Пример html_snippet"><code id="asb-code-snippet" class="add-sites-block__embed-code"></code></pre>
                <button
                  type="button"
                  class="add-sites-block__embed-copy"
                  data-asb-copy="#asb-code-snippet"
                >
                  Копировать в буфер обмена
                </button>
              </section>
            </div>
        </div>
      </section>
    </div>

    <div class="add-sites-block__page-actions">
      <button
        type="button"
        class="campaign-builder__button campaign-builder__button--primary add-sites-block__page-actions-btn"
        data-asb-create
      >
        Создать блок
      </button>
      <button
        type="button"
        class="campaign-builder__button campaign-builder__button--secondary add-sites-block__page-actions-btn"
        data-asb-done
        hidden
      >
        Готово
      </button>
    </div>
  </div>
</section>
