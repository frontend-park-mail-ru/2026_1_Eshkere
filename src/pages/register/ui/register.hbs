<section class="auth-page">
  <div class="auth-card">
    <h1 class="auth-card__title">Регистрация</h1>

    <form class="auth-form" id="register-form">
      {{{emailField}}}
      {{{phoneField}}}
      {{{passwordField}}}
      {{{repeatPasswordField}}}

      <div class="auth-form-not-input">
        {{{submitButton}}}
        {{{loginLinkButton}}}

        <div class="auth-divider">
          <span>или</span>
        </div>

        <button type="button" class="social-button social-button--vk" disabled aria-disabled="true" title="Скоро будет доступно">
          <span class="social-button__icon" aria-hidden="true">
            <img src="/icons/VK_logo_Blue_40x40.svg" alt="" />
          </span>
          <span class="social-button__label">VK ID</span>
        </button>

        <button type="button" class="social-button social-button--yandex" disabled aria-disabled="true" title="Скоро будет доступно">
          <span class="social-button__icon" aria-hidden="true">
            <img src="/icons/yandex-id.svg" alt="" />
          </span>
          <span class="social-button__label">Яндекс ID</span>
        </button>
      </div>
    </form>
  </div>
</section>

