<section class="campaigns-page">
  <div class="campaigns-page__toolbar">
    <div class="campaigns-page__toolbar-primary">
      <a class="campaigns-page__create-button" href="/ads/create">
        Создать кампанию
      </a>
    </div>

    <div class="campaigns-page__filters">
      <div class="campaigns-filter-wrap" data-filter-wrap>
        <button
          class="campaigns-page__filter"
          type="button"
          aria-expanded="false"
          data-filter-toggle
        >
          Фильтры
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true" data-filter-chevron>
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="campaigns-filter-dropdown" data-filter-dropdown hidden>
          <div class="campaigns-filter-dropdown__head">
            <span>Фильтры</span>
            <button class="campaigns-filter-dropdown__reset" type="button" data-filter-reset>Сбросить всё</button>
          </div>

          <div class="campaigns-filter-dropdown__section">
            <span class="campaigns-filter-dropdown__section-title">Статус</span>
            <div class="campaigns-filter-dropdown__options" role="group" aria-label="Фильтр по статусу">
              <label class="campaigns-filter-option">
                <input type="checkbox" value="moderation" data-filter-status /> На модерации
              </label>
              <label class="campaigns-filter-option">
                <input type="checkbox" value="working" data-filter-status /> Активные
              </label>
              <label class="campaigns-filter-option">
                <input type="checkbox" value="rejected" data-filter-status /> Отклонённые
              </label>
              <label class="campaigns-filter-option">
                <input type="checkbox" value="turned_off" data-filter-status /> Остановленные
              </label>
              <label class="campaigns-filter-option">
                <input type="checkbox" value="not_enough_money" data-filter-status /> Нет баланса
              </label>
            </div>
          </div>

          <div class="campaigns-filter-dropdown__divider"></div>

          <div class="campaigns-filter-dropdown__section">
            <span class="campaigns-filter-dropdown__section-title">Цель кампании</span>
            <div class="campaigns-filter-dropdown__options" role="group" aria-label="Фильтр по цели">
              <label class="campaigns-filter-option">
                <input type="checkbox" value="click" data-filter-goal /> Переходы на сайт
              </label>
              <label class="campaigns-filter-option">
                <input type="checkbox" value="look" data-filter-goal /> Охват и узнаваемость
              </label>
            </div>
          </div>

          <div class="campaigns-filter-dropdown__divider"></div>

          <div class="campaigns-filter-dropdown__section">
            <span class="campaigns-filter-dropdown__section-title">Сортировка</span>
            <div class="campaigns-filter-dropdown__options" role="group" aria-label="Сортировка">
              <label class="campaigns-filter-option">
                <input type="radio" name="campaigns-sort" value="" data-filter-sort checked /> По умолчанию
              </label>
              <label class="campaigns-filter-option">
                <input type="radio" name="campaigns-sort" value="name-asc" data-filter-sort /> Название А → Я
              </label>
              <label class="campaigns-filter-option">
                <input type="radio" name="campaigns-sort" value="name-desc" data-filter-sort /> Название Я → А
              </label>
              <label class="campaigns-filter-option">
                <input type="radio" name="campaigns-sort" value="budget-desc" data-filter-sort /> Бюджет: высокий → низкий
              </label>
              <label class="campaigns-filter-option">
                <input type="radio" name="campaigns-sort" value="budget-asc" data-filter-sort /> Бюджет: низкий → высокий
              </label>
            </div>
          </div>
        </div>
      </div>
      <input
        class="campaigns-page__search"
        type="search"
        id="campaigns-search"
        placeholder="Поиск кампаний"
        aria-label="Поиск кампаний"
      />
    </div>
  </div>


  {{#if loadError}}
    <div data-campaigns-load-error hidden>{{loadError}}</div>
  {{/if}}

  <div class="campaigns-table">
    <div class="campaigns-table__header">
      <div>Кампания</div>
      <div>Состав</div>
      <div>Цель</div>
      <div>Бюджет / день</div>
      <div>Статус</div>
      <div>Управление</div>
    </div>

    {{#if hasCampaigns}}
      <div class="campaigns-table__body">
        {{#each campaigns}}
          <div
            class="campaign-row"
            data-campaign-id="{{id}}"
            data-campaign-title="{{title}}"
            data-campaign-budget-value="{{budgetValue}}"
            data-campaign-goal="{{goal}}"
            data-status-key="{{statusKey}}"
          >
            <div class="campaign-row__name">
              <a class="campaign-row__detail-link" href="/ads/campaign?id={{id}}" data-campaign-detail-link="{{id}}">{{title}}</a>
            </div>
            <div>
              <span class="campaign-row__composition campaign-row__composition--{{compositionType}}">
                {{composition}}
              </span>
            </div>
            <div>{{goal}}</div>
            <div class="campaign-row__budget">{{budget}}</div>

            <div>
              <span class="status-badge status-badge--{{statusType}}" data-campaign-status-badge>
                {{status}}
              </span>
            </div>

            <div class="campaign-row__actions">
              <button
                type="button"
                class="campaign-row__actions-trigger js-campaign-actions-trigger"
                aria-label="Действия"
                aria-expanded="false"
              >
                <span class="campaign-row__actions-trigger-glyph" aria-hidden="true">
                  <svg
                    viewBox="0 0 24 24"
                    class="campaign-row__actions-trigger-glyph-icon"
                  >
                    <path d="M4 17.25V20h2.75l8.1-8.1-2.75-2.75-8.1 8.1ZM18.71 7.04a1 1 0 0 0 0-1.42l-1.33-1.33a1 1 0 0 0-1.42 0l-1.56 1.56 2.75 2.75 1.56-1.56Z"/>
                  </svg>
                </span>
                <span class="campaign-row__actions-trigger-label">Действия</span>
                <svg viewBox="0 0 24 24" class="campaign-row__actions-trigger-icon" aria-hidden="true">
                  <path d="M7 10.75a1.25 1.25 0 1 0 0 2.5 1.25 1.25 0 0 0 0-2.5Zm5 0a1.25 1.25 0 1 0 0 2.5 1.25 1.25 0 0 0 0-2.5Zm5 0a1.25 1.25 0 1 0 0 2.5 1.25 1.25 0 0 0 0-2.5Z"/>
                </svg>
              </button>
              <button type="button" class="campaign-row__action-button campaign-row__action-button--edit js-edit-action-trigger" aria-label="Редактировать">
                <svg viewBox="0 0 24 24" class="campaign-row__action-icon campaign-row__action-icon--edit">
                  <path d="M4 19.25V16.5L14.6 5.9a1.5 1.5 0 0 1 2.12 0l1.38 1.38a1.5 1.5 0 0 1 0 2.12L7.5 20H4.75A.75.75 0 0 1 4 19.25Zm2.06-.75h1.13l9.85-9.85-1.13-1.13L6.06 17.37v1.13ZM4 6.75A2.75 2.75 0 0 1 6.75 4H10a.75.75 0 0 1 0 1.5H6.75c-.69 0-1.25.56-1.25 1.25V17a.75.75 0 0 1-1.5 0V6.75ZM14 20a.75.75 0 0 1 0-1.5h3.25c.69 0 1.25-.56 1.25-1.25V14a.75.75 0 0 1 1.5 0v3.25A2.75 2.75 0 0 1 17.25 20H14Z"/>
                </svg>
              </button>

              <button type="button" class="campaign-row__action-button campaign-row__action-button--delete js-delete-action-trigger" aria-label="Удалить">
                <svg viewBox="0 0 24 24" class="campaign-row__action-icon campaign-row__action-icon--delete">
                  <path d="M9 3.75A1.75 1.75 0 0 1 10.75 2h2.5A1.75 1.75 0 0 1 15 3.75V4h3.25a.75.75 0 0 1 0 1.5h-.77l-.63 12.03A2 2 0 0 1 14.85 19.5H9.15a2 2 0 0 1-2-1.97L6.52 5.5h-.77a.75.75 0 0 1 0-1.5H9v-.25Zm1.5.25h3v-.25a.25.25 0 0 0-.25-.25h-2.5a.25.25 0 0 0-.25.25V4Zm-1.85 14h6.7a.5.5 0 0 0 .5-.48L16.47 5.5H7.53l.62 12.02a.5.5 0 0 0 .5.48ZM10 8.75a.75.75 0 0 1 1.5 0v5.5a.75.75 0 0 1-1.5 0v-5.5Zm2.5 0a.75.75 0 0 1 1.5 0v5.5a.75.75 0 0 1-1.5 0v-5.5Z"/>
                </svg>
              </button>

              <label class="toggle">
                <input
                  type="checkbox"
                  {{#if enabled}}checked{{/if}}
                />
                <span class="toggle__slider"></span>
              </label>
            </div>
          </div>
        {{/each}}
      </div>

      <div class="campaigns-table__footer" data-campaigns-pagination>
        <button
          class="campaigns-table__page-nav campaigns-table__page-nav--prev"
          type="button"
          data-pagination-prev
        >
          ← Предыдущее
        </button>

        <div class="campaigns-table__page-list" data-pagination-pages></div>

        <button
          class="campaigns-table__page-nav campaigns-table__page-nav--next"
          type="button"
          data-pagination-next
        >
          Следующее →
        </button>
      </div>
    {{else}}
      <div class="campaigns-empty">
        <div class="campaigns-empty__illustration" aria-hidden="true">
          <picture>
            <source srcset="/img/empty-campaign.png" type="image/png" />
            <img class="campaigns-empty__image" src="/img/empty-campaign.png" alt="" />
          </picture>
        </div>
        <h3 class="campaigns-empty__title">Здесь пока ничего нет...</h3>
        <button class="campaigns-empty__create-button" type="button">Создать кампанию</button>
      </div>
    {{/if}}
  </div>

  <div class="campaigns-delete-modal" id="campaigns-delete-modal" hidden>
    <div class="campaigns-delete-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="campaigns-delete-modal-title">
      <div class="campaigns-delete-modal__head">
        <h3 class="campaigns-delete-modal__title" id="campaigns-delete-modal-title">
          Удалить кампанию
        </h3>
        <p class="campaigns-delete-modal__text">
          Подтвердите действие, если хотите удалить кампанию.
        </p>
      </div>

      <div class="campaigns-delete-modal__illustration" aria-hidden="true">
        <span class="campaigns-delete-modal__blob"></span>
        <img class="campaigns-delete-modal__image" src="/img/trash.png" alt="" />
      </div>

      <div class="campaigns-delete-modal__note">
        После удаления невозможно будет вернуть эту кампанию снова в работу.
      </div>

      <div class="campaigns-delete-modal__actions">
        <button type="button" class="campaigns-delete-modal__button campaigns-delete-modal__button--secondary" id="campaigns-delete-cancel">
          Остаться
        </button>
        <button type="button" class="campaigns-delete-modal__button campaigns-delete-modal__button--primary" id="campaigns-delete-confirm">
          Удалить
        </button>
      </div>
    </div>
  </div>

  <div class="campaigns-status-modal" id="campaigns-status-modal" hidden>
    <div
      class="campaigns-status-modal__dialog"
      role="dialog"
      aria-modal="true"
      aria-labelledby="campaigns-status-modal-title"
    >
      <div class="campaigns-status-modal__head">
        <h3 class="campaigns-status-modal__title" id="campaigns-status-modal-title">
          Подтвердите изменение статуса
        </h3>
        <p class="campaigns-status-modal__text" id="campaigns-status-modal-text">
          После подтверждения статус кампании будет обновлен.
        </p>
      </div>

      <div class="campaigns-status-modal__illustration" aria-hidden="true">
        <span class="campaigns-status-modal__blob"></span>
        <img
          class="campaigns-status-modal__image"
          id="campaigns-status-modal-image"
          src="/img/Bored.png"
          alt=""
        />
      </div>

      <div class="campaigns-status-modal__note" id="campaigns-status-modal-note">
        Вы можете вернуться позже и снова изменить состояние кампании.
      </div>

      <div class="campaigns-status-modal__actions">
        <button
          type="button"
          class="campaigns-status-modal__button campaigns-status-modal__button--secondary"
          id="campaigns-status-cancel"
        >
          Отмена
        </button>
        <button
          type="button"
          class="campaigns-status-modal__button campaigns-status-modal__button--primary"
          id="campaigns-status-confirm"
        >
          Подтвердить
        </button>
      </div>
    </div>
  </div>
</section>
