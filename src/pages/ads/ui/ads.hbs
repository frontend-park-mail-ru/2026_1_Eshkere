<section class="campaigns-page">
  <div class="campaigns-page__toolbar">
    <div class="campaigns-page__toolbar-primary">
      <a class="campaigns-page__create-button" href="/ads/create">
        Создать кампанию
      </a>
    </div>

    <div class="campaigns-page__filters">
      <button class="campaigns-page__date-filter" type="button" id="date-filter-toggle">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M7 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h1a3 3 0 0 1 3 3v12a3 3 0 0 1-3 3H5a3 3 0 0 1-3-3V7a3 3 0 0 1 3-3h1V3a1 1 0 0 1 1-1Zm13 8H4v9a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-9ZM5 6a1 1 0 0 0-1 1v1h16V7a1 1 0 0 0-1-1H5Zm3 7a1 1 0 0 1 0 2H8a1 1 0 0 1 0-2Zm4 0a1 1 0 0 1 0 2h0a1 1 0 0 1 0-2Zm4 0a1 1 0 0 1 0 2h0a1 1 0 0 1 0-2Z" fill="currentColor"/>
        </svg>
        <span id="date-filter-label">9 мар - 9 апр 2026</span>
      </button>

      <div class="campaigns-page__filter">Фильтры</div>
      <input
        class="campaigns-page__search"
        type="search"
        id="campaigns-search"
        placeholder="Поиск кампаний"
        aria-label="Поиск кампаний"
      />
    </div>
  </div>

  <div class="campaigns-date-picker" id="campaigns-date-picker" hidden>
    <div class="campaigns-date-picker__presets" role="radiogroup" aria-label="Быстрые периоды">
      <button class="campaigns-date-picker__preset" type="button" data-preset="today">Сегодня</button>
      <button class="campaigns-date-picker__preset" type="button" data-preset="week">Эта неделя</button>
      <button class="campaigns-date-picker__preset" type="button" data-preset="month">Этот месяц</button>
      <button class="campaigns-date-picker__preset" type="button" data-preset="year">Этот год</button>
      <button class="campaigns-date-picker__preset is-active" type="button" data-preset="manual">Вручную</button>
    </div>

    <div class="campaigns-date-picker__calendar">
      <div class="campaigns-date-picker__months">
        <div class="campaigns-date-picker__month">
          <div class="campaigns-date-picker__month-header">
            <button type="button" class="campaigns-date-picker__nav" id="date-prev">«</button>
            <button type="button" class="campaigns-date-picker__nav" id="date-prev-month">‹</button>
            <strong id="date-month-left-label"></strong>
            <button type="button" class="campaigns-date-picker__nav" id="date-next-month">›</button>
            <button type="button" class="campaigns-date-picker__nav" id="date-next">»</button>
          </div>
          <div class="campaigns-date-picker__weekdays">
            <span>П</span><span>В</span><span>С</span><span>Ч</span><span>П</span><span>С</span><span>В</span>
          </div>
          <div class="campaigns-date-picker__grid" id="date-grid-left"></div>
        </div>

        <div class="campaigns-date-picker__month">
          <div class="campaigns-date-picker__month-header">
            <button type="button" class="campaigns-date-picker__nav" id="date-prev-right">«</button>
            <button type="button" class="campaigns-date-picker__nav" id="date-prev-month-right">‹</button>
            <strong id="date-month-right-label"></strong>
            <button type="button" class="campaigns-date-picker__nav" id="date-next-month-right">›</button>
            <button type="button" class="campaigns-date-picker__nav" id="date-next-right">»</button>
          </div>
          <div class="campaigns-date-picker__weekdays">
            <span>П</span><span>В</span><span>С</span><span>Ч</span><span>П</span><span>С</span><span>В</span>
          </div>
          <div class="campaigns-date-picker__grid" id="date-grid-right"></div>
        </div>
      </div>

      <div class="campaigns-date-picker__footer">
        <div class="campaigns-date-picker__range">
          <span id="date-range-from">09.03.2026</span>
          <span>-</span>
          <span id="date-range-to">09.04.2026</span>
        </div>
        <div class="campaigns-date-picker__actions">
          <button type="button" class="campaigns-date-picker__action campaigns-date-picker__action--cancel" id="date-cancel">
            Отмена
          </button>
          <button type="button" class="campaigns-date-picker__action campaigns-date-picker__action--apply" id="date-apply">
            Применить
          </button>
        </div>
      </div>
    </div>
  </div>

  {{#if loadError}}
    <div class="campaigns-page__message campaigns-page__message--error">
      Не удалось загрузить объявления: {{loadError}}
    </div>
  {{/if}}

  <div class="campaigns-table">
    <div class="campaigns-table__header">
      <div>Название</div>
      <div>Бюджет</div>
      <div>Целевое действие</div>
      <div>Дата последнего действия</div>
      <div>Действие</div>
      <div>Статус</div>
      <div>Вкл/выкл</div>
    </div>

    {{#if hasCampaigns}}
      <div class="campaigns-table__body">
        {{#each campaigns}}
          <div
            class="campaign-row"
            data-campaign-id="{{id}}"
            data-campaign-title="{{title}}"
            data-campaign-budget-value="{{budgetValue}}"
            data-campaign-goal="{{goal}}"
          >
            <div class="campaign-row__name">{{title}}</div>
            <div>{{budget}}</div>
            <div>{{goal}}</div>
            <div>{{lastActionDate}}</div>

            <div class="campaign-row__actions">
              <button
                type="button"
                class="campaign-row__actions-trigger js-campaign-actions-trigger"
                aria-label="Действия"
                aria-expanded="false"
              >
                <span class="campaign-row__actions-trigger-glyph" aria-hidden="true">
                  <svg
                    viewBox="0 0 24 24"
                    class="campaign-row__actions-trigger-glyph-icon"
                  >
                    <path d="M4 17.25V20h2.75l8.1-8.1-2.75-2.75-8.1 8.1ZM18.71 7.04a1 1 0 0 0 0-1.42l-1.33-1.33a1 1 0 0 0-1.42 0l-1.56 1.56 2.75 2.75 1.56-1.56Z"/>
                  </svg>
                </span>
                <span class="campaign-row__actions-trigger-label">Действия</span>
                <svg viewBox="0 0 24 24" class="campaign-row__actions-trigger-icon" aria-hidden="true">
                  <path d="M7 10.75a1.25 1.25 0 1 0 0 2.5 1.25 1.25 0 0 0 0-2.5Zm5 0a1.25 1.25 0 1 0 0 2.5 1.25 1.25 0 0 0 0-2.5Zm5 0a1.25 1.25 0 1 0 0 2.5 1.25 1.25 0 0 0 0-2.5Z"/>
                </svg>
              </button>
              <button type="button" class="campaign-row__action-button campaign-row__action-button--edit js-edit-action-trigger" aria-label="Редактировать">
                <svg viewBox="0 0 24 24" class="campaign-row__action-icon campaign-row__action-icon--edit">
                  <path d="M4 19.25V16.5L14.6 5.9a1.5 1.5 0 0 1 2.12 0l1.38 1.38a1.5 1.5 0 0 1 0 2.12L7.5 20H4.75A.75.75 0 0 1 4 19.25Zm2.06-.75h1.13l9.85-9.85-1.13-1.13L6.06 17.37v1.13ZM4 6.75A2.75 2.75 0 0 1 6.75 4H10a.75.75 0 0 1 0 1.5H6.75c-.69 0-1.25.56-1.25 1.25V17a.75.75 0 0 1-1.5 0V6.75ZM14 20a.75.75 0 0 1 0-1.5h3.25c.69 0 1.25-.56 1.25-1.25V14a.75.75 0 0 1 1.5 0v3.25A2.75 2.75 0 0 1 17.25 20H14Z"/>
                </svg>
              </button>

              <button type="button" class="campaign-row__action-button campaign-row__action-button--delete js-delete-action-trigger" aria-label="Удалить">
                <svg viewBox="0 0 24 24" class="campaign-row__action-icon campaign-row__action-icon--delete">
                  <path d="M9 3.75A1.75 1.75 0 0 1 10.75 2h2.5A1.75 1.75 0 0 1 15 3.75V4h3.25a.75.75 0 0 1 0 1.5h-.77l-.63 12.03A2 2 0 0 1 14.85 19.5H9.15a2 2 0 0 1-2-1.97L6.52 5.5h-.77a.75.75 0 0 1 0-1.5H9v-.25Zm1.5.25h3v-.25a.25.25 0 0 0-.25-.25h-2.5a.25.25 0 0 0-.25.25V4Zm-1.85 14h6.7a.5.5 0 0 0 .5-.48L16.47 5.5H7.53l.62 12.02a.5.5 0 0 0 .5.48ZM10 8.75a.75.75 0 0 1 1.5 0v5.5a.75.75 0 0 1-1.5 0v-5.5Zm2.5 0a.75.75 0 0 1 1.5 0v5.5a.75.75 0 0 1-1.5 0v-5.5Z"/>
                </svg>
              </button>
            </div>

            <div>
              <span class="status-badge status-badge--{{statusType}}">
                {{status}}
              </span>
            </div>

            <div>
              <label class="toggle">
                <input
                  type="checkbox"
                  {{#if enabled}}checked{{/if}}
                />
                <span class="toggle__slider"></span>
              </label>
            </div>
          </div>
        {{/each}}
      </div>

      <div class="campaigns-table__footer" data-campaigns-pagination>
        <button
          class="campaigns-table__page-nav campaigns-table__page-nav--prev"
          type="button"
          data-pagination-prev
        >
          ← Предыдущее
        </button>

        <div class="campaigns-table__page-list" data-pagination-pages></div>

        <button
          class="campaigns-table__page-nav campaigns-table__page-nav--next"
          type="button"
          data-pagination-next
        >
          Следующее →
        </button>
      </div>
    {{else}}
      <div class="campaigns-empty">
        <div class="campaigns-empty__illustration" aria-hidden="true">
          <picture>
            <source srcset="/img/empty-campaign.png" type="image/png" />
            <img class="campaigns-empty__image" src="/img/empty-campaign.png" alt="" />
          </picture>
        </div>
        <h3 class="campaigns-empty__title">Здесь пока ничего нет...</h3>
        <button class="campaigns-empty__create-button" type="button">Создать кампанию</button>
      </div>
    {{/if}}
  </div>

  <div class="campaigns-delete-modal" id="campaigns-delete-modal" hidden>
    <div class="campaigns-delete-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="campaigns-delete-modal-title">
      <div class="campaigns-delete-modal__head">
        <h3 class="campaigns-delete-modal__title" id="campaigns-delete-modal-title">
          Удалить кампанию
        </h3>
        <p class="campaigns-delete-modal__text">
          Подтвердите действие, если хотите удалить кампанию.
        </p>
      </div>

      <div class="campaigns-delete-modal__illustration" aria-hidden="true">
        <span class="campaigns-delete-modal__blob"></span>
        <img class="campaigns-delete-modal__image" src="/img/trash.png" alt="" />
      </div>

      <div class="campaigns-delete-modal__note">
        После удаления невозможно будет вернуть эту кампанию снова в работу.
      </div>

      <div class="campaigns-delete-modal__actions">
        <button type="button" class="campaigns-delete-modal__button campaigns-delete-modal__button--secondary" id="campaigns-delete-cancel">
          Остаться
        </button>
        <button type="button" class="campaigns-delete-modal__button campaigns-delete-modal__button--primary" id="campaigns-delete-confirm">
          Удалить
        </button>
      </div>
    </div>
  </div>
</section>
